{
  "name": "@etus/telemetry-dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Internal dashboard on Cloudflare Pages — adoption metrics for ETUS OSS, queries D1 via getRequestContext.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "next build && pnpm exec next-on-pages",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "pnpm build:pages && wrangler pages deploy .vercel/output/static",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .vercel .turbo"
  },
  "dependencies": {
    "next": "^15.0.0",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.0",
    "vercel": "^39.0.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20"
  }
}
