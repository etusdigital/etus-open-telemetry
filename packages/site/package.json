{
  "name": "@etus/telemetry-site",
  "version": "0.0.0",
  "private": true,
  "description": "Public site: landing + privacy policy + Homebrew-style public stats viewer (Cloudflare Pages).",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "build:pages": "next build && pnpm exec next-on-pages",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "pnpm build:pages && wrangler pages deploy .vercel/output/static",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .vercel out .turbo"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "@tailwindcss/typography": "^0.5.15",
    "typescript": "^5.5.0",
    "vercel": "^39.0.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20"
  }
}
