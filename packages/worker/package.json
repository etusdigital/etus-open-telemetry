{
  "name": "@etus/telemetry-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker: ingestor (HTTP), persistor (queue consumer) and aggregator (cron) for etus-open-telemetry.",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev --persist-to ../../.wrangler/state",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:migrate:local": "wrangler d1 migrations apply etus-telemetry --local --persist-to ../../.wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply etus-telemetry --remote",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "dependencies": {
    "@etus/telemetry-schema": "workspace:*",
    "@etus/telemetry-shared": "workspace:*",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20"
  }
}
